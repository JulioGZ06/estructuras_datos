  <property name="styleSheet">
   <string notr="true">/* =========================
   QDialog - World Cup Dark
   ========================= */
QDialog {
    background-color: #121212;
    border: 2px solid #C9A227;
    border-radius: 15px;
}

/* =========================
   QLabel
   ========================= */
QLabel {
    color: #FFFFFF;
    font-size: 14px;
    font-weight: bold;
    background: transparent;
}

/* Títulos */
QLabel#titulo {
    color: #C9A227;
    font-size: 24px;
    font-weight: bold;
    padding: 10px;
}

/* =========================
   QLineEdit
   ========================= */
QLineEdit {
    background-color: #1E1E1E;
    color: #FFFFFF;
    border: 2px solid #2E8B57;
    border-radius: 8px;
    padding: 8px;
    font-size: 14px;
    selection-background-color: #C9A227;
}

QLineEdit:focus {
    border: 2px solid #C9A227;
    background-color: #252525;
}

/* =========================
   QPushButton
   ========================= */
QPushButton {
    background-color: #006847;
    color: white;
    border: 2px solid #C9A227;
    border-radius: 10px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #008F5A;
    border: 2px solid #FFD700;
}

QPushButton:pressed {
    background-color: #004D33;
    padding-top: 10px;
}

/* Botón principal */
QPushButton#btnPrincipal {
    background-color: #C9A227;
    color: #121212;
    border: 2px solid #FFD700;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#btnPrincipal:hover {
    background-color: #FFD700;
}

/* =========================
   ToolTips
   ========================= */
QToolTip {
    background-color: #1E1E1E;
    color: white;
    border: 1px solid #C9A227;
    padding: 5px;
}</string>
